ErrorDocument 404 /404.php

RewriteEngine On
RewriteBase /

# Явный маршрут для /profile, чтобы не перехватывался существующей папкой /profile/
RewriteRule ^profile/?$ profile.php [L]

# Если файл/папка существует — отдаем как есть
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Добавить .php для реальных файлов
RewriteRule ^(.+?)/?$ $1.php [L]